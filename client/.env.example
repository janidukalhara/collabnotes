# ─────────────────────────────────────────────────────────────────────────────
# CollabNotes — Client Environment Variables
# Copy to .env and adjust. Variables MUST be prefixed with VITE_ to be
# accessible in the browser bundle.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the Express API (no trailing slash)
VITE_API_URL=http://localhost:5000/api
